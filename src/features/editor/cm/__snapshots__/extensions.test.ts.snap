exports[`createEditorExtensions > renders a themed CodeMirror editor in jsdom 1`] = `"<div class="cm-editor cm-token cm-token cm-token"><div class="cm-announced" aria-live="polite"></div><div tabindex="-1" class="cm-scroller"><div class="cm-gutters cm-gutters-before" aria-hidden="true" style="min-height: 42px; position: sticky;"><div class="cm-gutter cm-lineNumbers"><div class="cm-gutterElement" style="height: 0px; visibility: hidden; pointer-events: none;">9</div><div class="cm-gutterElement cm-activeLineGutter" style="height: 14px;">1</div><div class="cm-gutterElement" style="height: 14px;">2</div><div class="cm-gutterElement" style="height: 14px;">3</div></div></div><div style="tab-size: 2;" spellcheck="false" autocorrect="off" autocapitalize="off" writingsuggestions="false" translate="no" contenteditable="true" class="cm-content cm-lineWrapping" role="textbox" aria-multiline="true" data-language="markdown"><div class="cm-line cm-activeLine cm-heading-1"><span class="cm-token"># Heading</span></div><div class="cm-line"><br></div><div class="cm-line"><span class="cm-wikilink-bracket-hidden">[<span class="cm-token">[</span></span><span class="cm-token">Link</span><span class="cm-wikilink-bracket-hidden"><span class="cm-token">]</span>]</span> #tag</div></div></div></div>"`;
